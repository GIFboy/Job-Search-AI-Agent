# Copy to ~/.config/job-agent/secrets.env  (chmod 600) and fill in real values.
# These are injected into the OpenClaw gateway via the systemd drop-in
# systemd/job-agent.conf.example so the agent's exec tool can use them.

RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_HOST=jsearch.p.rapidapi.com
HUNTER_API_KEY=your_hunter_io_key_here
